# Jarvis platform — copy to .env and fill in.

# Core
NVIDIA_API_KEY=
JARVIS_ENGINE=hermes
JARVIS_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Odysseus
ODYSSEUS_PORT=7000
AUTH_ENABLED=true
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=

# Odysseus shared memory bridge (PHASE-3.md §1) — create a token with
# memory:read,memory:write scope in Odysseus's settings UI and paste it here.
ODYSSEUS_API_TOKEN=

# Sentinel scheduler notifications (PHASE-3.md §2.4)
NTFY_BASE_URL=http://ntfy:80
NTFY_TOPIC=jarvis

# Telegram remote bridge (PHASE-5.md §2) — both must be set or the bridge
# stays off. Token from @BotFather; chat id: message your bot once, then
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
# and read result[0].message.chat.id.
# NOTE: enabling this sends mission content/sitreps to Telegram's servers.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
